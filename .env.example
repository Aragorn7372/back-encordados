# ============================================
# BACKENCORDADOS - Configuration Environment
# ============================================

# JWT Authentication (REQUIRED - generate a secure key with at least 32 characters)
JWT_KEY=your_secure_jwt_key_here_min_32_characters
JWT_ISSUER=Encordados
JWT_AUDIENCE=Encordados

# WhatsApp Configuration (REQUIRED for WhatsApp messaging)
WhatsAppEnabled=true
WhatsAppPhoneNumberId=
WhatsAppAccessToken=
WhatsAppApiVersion=v25.0

# PostgreSQL Database URLs (REQUIRED for production)
# Format: Host=host;Port=port;Database=db;Username=user;Password=pass;Pooling=false;Maximum Pool Size=5;Trust Server Certificate=true;Ssl Mode=Require;Command Timeout=60
DATABASE_URL_USER=Host=host;Port=5432;Database=postgres;Username=user;Password=pass;Pooling=false;Maximum Pool Size=5;Trust Server Certificate=true;Ssl Mode=Require;Command Timeout=60
DATABASE_URL_MATERIALS=Host=host;Port=5432;Database=postgres;Username=user;Password=pass;Pooling=false;Maximum Pool Size=5;Trust Server Certificate=true;Ssl Mode=Require;Command Timeout=60

# MongoDB Connection Strings (REQUIRED for production)
MONGODB_URI_TALLERES=mongodb+srv://user:password@cluster.mongodb.net/?appName=AppName
MONGODB_URI_PEDIDOS=mongodb+srv://user:password@cluster.mongodb.net/?appName=AppName

# Redis Cache (REQUIRED for production)
REDIS_CACHE_URL=redis://localhost:6379/0

# SMTP Email Configuration (REQUIRED for production)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROMEMAIL=your_email@example.com
SMTP_FROMNAME=BackEncordados
SMTP_ADMINEMAIL=admin@example.com

# Cloudinary Configuration (REQUIRED for image uploads)
Cloudinary_CloudName=your_cloudinary_cloud_name
Cloudinary_ApiKey=your_cloudinary_api_key
Cloudinary_ApiSecret=your_cloudinary_api_secret

# Stripe Payment (optional)
STRIPE_KEY=

# Server URL
SERVER_URL=https://your-domain.com
